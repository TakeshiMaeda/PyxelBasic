1000 REM --paddle--
1010 S = STICK(0)
1020 IF (S AND 4) = 4 AND (PX>64) THEN PX=PX-PV
1030 IF (S AND 8) = 8 AND (PX+PW<192) THEN PX=PX+PV
1040 LINEBF(PX,PY)-(PX+PW-1,PY+PH-1),7
1050 IF PX<PBX THEN LINEBF(PBX+PW-PV-1,PY)-(PBX+PW-1,PY+PH-1),1
1060 IF PX>PBX THEN LINEBF(PBX,PY)-(PBX+PV-1,PY+PH-1),1
1065 PBX=PX
1070 RETURN
2000 REM --ball--
2010 BBX=BX:BBY=BY
2020 BX=BX+BVX:BY=BY+BVY
2025 IF BX<64+BR OR BX>=192-BR THEN BX=BBX:BY=BBY:BVX=-BVX:GOTO 2020
2026 IF BY<32+BR OR BY>=224-BR THEN BX=BBX:BY=BBY:BVY=-BVY:GOTO 2020
2030 X=BX:Y=BY:GOSUB 2700:IF F=1 THEN 2020
2050 X=BX-BR+1:Y=BY-BR+1:GOSUB 2700:IF F=1 THEN 2020
2060 X=BX+BR-1:Y=BY-BR+1:GOSUB 2700:IF F=1 THEN 2020
2070 X=BX-BR+1:Y=BY+BR-1:GOSUB 2700:IF F=1 THEN 2020
2080 X=BX+BR-1:Y=BY+BR-1:GOSUB 2700:IF F=1 THEN 2020
2090 P=POINT(BX,BY)
2100 IF P<>7 THEN 2200
2110 X=ABS((PX+12)-BX)
2120 IF X>=PW/2-3 AND BVX<8 THEN BVX=BVX*1.1
2140 IF X<=2 AND BVX>1 THEN BVX=BVX*0.9
2150 BX=BBX:BY=BBY:BVY=-BVY:GOTO 2020
2200 CIRCLEBF(BBX,BBY),BR,1
2210 CIRCLEBF(BX,BY),BR,11
2220 RETURN
2700 X=FIX((X-64)/16):Y=FIX((Y-32)/8)
2702 IF X>=8 OR Y>=8 THEN F=0:RETURN
2705 IF BL(X,Y) <> 1 THEN F=0:RETURN
2710 BL(X,Y)=0
2720 X=X*16+64:Y=Y*8+32
2730 LINEBF(X,Y)-(X+15,Y+7),1
2735 IF BCT>0 THEN BCT=BCT-1
2740 BX=BBX:BY=BBY:BVY=-BVY
2750 F=1:RETURN
