10 CLS : VSYNC CLEAR
16 LINEBF (56,24)-(199,223),5
17 LINEBF (64,32)-(191,223),1
19 DIM BL(8,8)
20 FOR Y=0 TO 7 : FOR X=0 TO 7
22 LINEB(64+X*16,32+Y*8)-(79+X*16,39+Y*8),6
23 LINEBF(64+X*16,32+Y*8)-(78+X*16,38+Y*8),2
24 BL(X,Y)=1
25 NEXT X : NEXT Y
27 BCT=8*8
30 PX=64:PY=198:PW=24:PH=6:PBX=PX:PV=2
40 BX=80:BY=190:BR=2:BVX=1:BVY=-3
50 SET SPRITE 0,"03330000333B3000333330003333300003330000000000000000000000000000"
60 SE1$=">c16":SE2$="c16"
100 REM --main--
110 GOSUB 1000
120 GOSUB 2000
130 IF BCT=0 THEN GOTO 500
140 IF BY>PY+PH+14 THEN 700
298 FOR W=0 TO 100:NEXT
299 VSYNC:VSYNC
300 GOTO 110
500 REM -- clear --
510 LOCATE 28,16:PRINT "ALL CLEAR "
520 LOCATE 25,17:PRINT "CONGRATULATIONS!"
540 END
700 REM -- game over --
710 LOCATE 28,16:PRINT "BALL OUT!"
720 LOCATE 28,17:PRINT "GAME OVER"
730 END
1000 REM --paddle--
1010 S = STICK(0)
1020 IF (S AND 4) = 4 AND (PX>64) THEN PX=PX-PV
1030 IF (S AND 8) = 8 AND (PX+PW<192) THEN PX=PX+PV
1040 LINEBF(PX,PY)-(PX+PW-1,PY+PH-1),7
1050 IF PX<PBX THEN LINEBF(PBX+PW-PV-1,PY)-(PBX+PW-1,PY+PH-1),1
1060 IF PX>PBX THEN LINEBF(PBX,PY)-(PBX+PV-1,PY+PH-1),1
1065 PBX=PX
1070 RETURN
2000 REM --ball--
2010 BBX=BX:BBY=BY
2020 BX=BX+BVX:BY=BY+BVY
2025 IF BX<64+BR OR BX>=192-BR THEN BX=BBX:BY=BBY:BVX=-BVX:PLAY SE2$
2026 IF BY<32+BR OR BY>=224-BR THEN BX=BBX:BY=BBY:BVY=-BVY:PLAY SE2$
2030 X=FIX((BX-64)/16):Y=FIX((BY-32)/8)
2040 IF X>=8 OR Y>=8 THEN 2090
2050 IF BL(X,Y) <> 1 THEN 2090
2060 BL(X,Y)=0 : PLAY SE1$
2070 X=X*16+64:Y=Y*8+32 : LINEBF(X,Y)-(X+15,Y+7),1
2080 IF BCT>0 THEN BCT=BCT-1
2082 IF ABS(BBX-(X+8))>=8 AND ABS(BX-(X+8))<8 THEN BX=BBX:BY=BBY:BVX=-BVX : PLAY SE1$
2085 IF ABS(BBY-(Y+4))>=4 AND ABS(BY-(Y+4))<4 THEN BX=BBX:BY=BBY:BVY=-BVY : PLAY SE1$
2090 P=POINT(BX,BY) : IF P<>7 THEN 2200
2100 IF (S AND 4)<>4 THEN 2120
2110 IF BVX<0 THEN BVX=BVX*1.1 ELSE IF (BVX*0.9)>0 THEN BVX=BVX*0.9
2120 IF (S AND 8)<>8 THEN 2140
2130 IF BVX>0 THEN BVX=BVX*1.1 ELSE IF (BVX*0.9)>0 THEN BVX=BVX*0.9
2140 X=ABS((PX+12)-BX)
2150 IF X>=6 THEN BVX=BVX*1.1
2160 IF X<=4 AND (BVX*0.9)>0 THEN BVX=BVX*0.9
2180 BX=BBX:BY=BBY:BVY=-BVY : PLAY SE2$
2200 PUT SPRITE 0,(BX-BR,BY-BR),0,0,0
2210 RETURN
