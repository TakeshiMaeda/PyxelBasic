10 REM SIMPLE GAME: MOVE A POINT WITH THE CURSOR KEYS
20 LET X = 128
30 LET Y = 128
40 CLS
50 IF STICK(0) AND 1 THEN GOTO 200
60 IF STICK(0) AND 2 THEN GOTO 220
70 IF STICK(0) AND 4 THEN GOTO 240
80 IF STICK(0) AND 8 THEN GOTO 260
90 GOTO 300
200 LET Y = Y - 2
210 GOTO 300
220 LET Y = Y + 2
230 GOTO 300
240 LET X = X - 2
250 GOTO 300
260 LET X = X + 2
300 PSET (X, Y), 10
310 GOTO 50
