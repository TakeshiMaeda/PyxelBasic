10 REM ============================================
20 REM  PyxelBasic - all command / function test
30 REM  Prints OK/NG per feature, summary at the end
40 REM ============================================
50 CLS
60 COLOR 7
70 F=0
80 PRINT "PYXELBASIC SELF TEST"
90 PRINT "===================="
100 REM --- operators ---
110 N$="ADD/MUL PRECEDENCE"
120 T=(1+2*3=7)
130 GOSUB 9000
140 N$="POWER"
150 T=(2^10=1024)
160 GOSUB 9000
170 N$="MOD"
180 T=(7 MOD 3=1)
190 GOSUB 9000
200 N$="REAL DIV"
210 T=(10/4=2.5)
220 GOSUB 9000
230 N$="UNARY MINUS"
240 T=(0-5+3=-2)
250 GOSUB 9000
260 N$="BIT/LOGIC"
270 T=((6 AND 3)=2 AND (5 OR 2)=7 AND (5 XOR 1)=4 AND (NOT 0)=-1)
280 GOSUB 9000
290 N$="COMPARE"
300 T=((3<5)=-1 AND (5<=5)=-1 AND (3>5)=0 AND (2<>2)=0)
310 GOSUB 9000
320 REM --- math functions ---
330 N$="SIN/COS/TAN/ATN"
340 T=(SIN(0)=0 AND COS(0)=1 AND TAN(0)=0 AND ATN(0)=0)
350 GOSUB 9000
360 N$="RAD/DEG"
370 T=(ABS(RAD(180)-3.14159)<0.001 AND ABS(DEG(3.14159)-180)<0.01)
380 GOSUB 9000
390 N$="EXP/LOG/LOG10"
400 T=(EXP(0)=1 AND LOG(1)=0 AND LOG10(1)=0)
410 GOSUB 9000
420 N$="SQR/ABS"
430 T=(SQR(16)=4 AND ABS(-7)=7)
440 GOSUB 9000
450 N$="INT/FIX/ROUND/SGN"
460 T=(INT(3.9)=3 AND FIX(-3.9)=-3 AND ROUND(3.4)=3 AND SGN(-5)=-1 AND SGN(0)=0)
470 GOSUB 9000
480 REM --- string functions ---
490 N$="LEN"
500 T=(LEN("HELLO")=5)
510 GOSUB 9000
520 N$="LEFT/RIGHT/MID"
530 T=(LEFT$("ABCDE",2)="AB" AND RIGHT$("ABCDE",2)="DE" AND MID$("ABCDE",2,3)="BCD")
540 GOSUB 9000
550 N$="CHR/ASC"
560 T=(CHR$(65)="A" AND ASC("A")=65)
570 GOSUB 9000
580 N$="STR/VAL"
590 T=(STR$(123)="123" AND VAL("45")=45 AND VAL("3.5")=3.5)
600 GOSUB 9000
610 N$="CONCAT"
620 T=("AB"+"CD"="ABCD" AND "N="+STR$(5)="N=5")
630 GOSUB 9000
640 REM --- variables and arrays ---
650 N$="LET"
660 LET X=10
670 T=(X=10)
680 GOSUB 9000
690 N$="IMPLICIT ASSIGN"
700 Y=20
710 T=(Y=20)
720 GOSUB 9000
730 N$="ARRAY 1D"
740 DIM A(5)
750 A(3)=99
760 T=(A(3)=99)
770 GOSUB 9000
780 N$="ARRAY 2D"
790 DIM B(2,2)
800 B(1,2)=77
810 T=(B(1,2)=77)
820 GOSUB 9000
830 N$="AUTO ARRAY"
840 C(4)=8
850 T=(C(4)=8)
860 GOSUB 9000
870 REM --- control flow ---
880 N$="IF/THEN STMT"
890 W=0
900 IF 1=1 THEN W=1
910 IF 1=0 THEN W=2
920 T=(W=1)
930 GOSUB 9000
940 N$="FOR/NEXT"
950 S=0
960 FOR I=1 TO 5
970 S=S+I
980 NEXT I
990 T=(S=15 AND I=6)
1000 GOSUB 9000
1010 N$="FOR STEP"
1020 K=0
1030 FOR J=10 TO 0 STEP -5
1040 K=K+1
1050 NEXT J
1060 T=(K=3)
1070 GOSUB 9000
1080 N$="GOTO"
1090 GG=1
1100 GOTO 1120
1110 GG=2
1120 T=(GG=1)
1130 GOSUB 9000
1140 N$="GOSUB/RETURN"
1150 H=0
1160 GOSUB 9500
1170 T=(H=5)
1180 GOSUB 9000
1190 N$="IF IMPLICIT GOTO"
1200 Z=0
1210 IF 1=1 THEN 1230
1220 Z=1
1230 T=(Z=0)
1240 GOSUB 9000
1250 REM --- DATA / READ / RESTORE ---
1255 DATA 11, 22, 33
1260 N$="DATA/READ/RESTORE"
1270 READ P
1280 READ Q
1290 RESTORE
1300 READ R
1310 T=(P=11 AND Q=22 AND R=11)
1320 GOSUB 9000
1322 DATA -5, +7, -0.5
1324 N$="DATA SIGNED + RESTORE LINE" : RESTORE 1322 : READ DA : READ DB : READ DC : T=(DA=-5 AND DB=7 AND DC=-0.5) : GOSUB 9000
1326 DATA 11, 22, 33
1328 N$="READ INTO ARRAY" : DIM RA(3) : RESTORE 1326 : READ RA(0) : READ RA(1) : READ RA(2) : T=(RA(0)=11 AND RA(1)=22 AND RA(2)=33) : GOSUB 9000
1330 REM --- random ---
1340 N$="RANDOMIZE/RND"
1350 RANDOMIZE 1
1360 RV=RND(1)
1370 T=(RV>=0 AND RV<1)
1380 GOSUB 9000
1390 REM --- input devices (exercised, value not asserted) ---
1400 N$="INKEY$"
1410 T=(LEN(INKEY$)>=0)
1420 GOSUB 9000
1430 N$="STICK"
1440 T=(STICK(0)>=0)
1450 GOSUB 9000
1460 N$="BUTTON"
1470 BV=BUTTON(0)
1480 T=(BV=0 OR BV=1)
1490 GOSUB 9000
1500 REM --- side-effect commands (run without error) ---
1510 N$="COLOR"
1520 COLOR 11
1530 COLOR 7
1540 T=-1
1550 GOSUB 9000
1560 N$="LOCATE"
1570 LOCATE 0,18
1580 T=-1
1590 GOSUB 9000
1600 N$="PSET"
1610 PSET(10,200,8)
1620 T=-1
1630 GOSUB 9000
1640 N$="LINE"
1650 LINE(0,210)-(40,230),11
1660 T=-1
1670 GOSUB 9000
1680 N$="CLS (done at start)"
1690 T=-1
1700 GOSUB 9000
1710 REM --- VSYNC variants ---
1720 N$="VSYNC CONFIG"
1730 VSYNC PRINT OFF
1740 VSYNC PRINT ON
1745 VSYNC CLEAR
1750 VSYNC RESET
1760 T=-1
1770 GOSUB 9000
1780 VSYNC LIST
1790 VSYNC
1791 REM --- ELSE and multi-statement (:) ---
1792 N$="IF/THEN/ELSE T":W=9:IF 1=1 THEN W=1 ELSE W=2
1793 T=(W=1):GOSUB 9000
1794 N$="IF/THEN/ELSE F":W=9:IF 1=0 THEN W=1 ELSE W=2
1795 T=(W=2):GOSUB 9000
1796 N$="MULTI STATEMENT":Q=0:Q=Q+1:Q=Q+2
1797 T=(Q=3):GOSUB 9000
1798 N$="ONE-LINE FOR/NEXT":SS=0:FOR I=1 TO 5:SS=SS+I:NEXT
1799 T=(SS=15):GOSUB 9000
1800 REM --- summary ---
1810 PRINT "===================="
1820 IF F=0 THEN PRINT "ALL TESTS PASSED"
1830 IF F>0 THEN PRINT STR$(F)+" TEST(S) FAILED"
1840 REM --- INPUT (interactive) ---
1850 PRINT "TYPE TEXT + ENTER:"
1860 INPUT IN$
1870 PRINT "YOU TYPED: ";IN$
1880 REM STOP ends the program identically to END
1890 END
9000 REM --- result printer: T = pass(-1)/fail(0), N$ = name ---
9010 IF T THEN PRINT "OK  ";N$
9020 IF T=0 THEN PRINT "NG  ";N$
9030 IF T=0 THEN F=F+1
9040 RETURN
9500 REM --- subroutine target for the GOSUB test ---
9510 H=5
9520 RETURN
