10 REM --- fire works ---
20 CLS
30 RESTORE : READ RE
40 DIM RSX(RE),RSY(RE),REX(RE),REY(RE)
50 FOR I=1 TO RE
60 READ RSX(I),RSY(I),REX(I),REY(I)
70 NEXT
80 READ FE
90 DIM X(FE),Y(FE),FAX(FE),FSX(FE),FAY(FE),FEY(FE),CL(FE),AX(FE),AY(FE)
100 FOR J=1 TO FE
110 READ FAX(J),FSX(J),FAY(J),FEY(J)
120 NEXT
130 CL=11
140 FOR I=1 TO RE
150 SX=RSX(I):SY=RSY(I):EX=REX(I):EY=REY(I)
160 GOSUB 190
170 NEXT
180 END
190 DX = ABS(EX-SX)+1 : DY = ABS(EY-SY)+1
200 SSX=SGN(EX-SX) : X=SX : Y=SY : ACC = 0
210 BX=X : BY = Y
220 ACC=ACC+DX : Y=Y-1
230 IF ACC >= DY THEN ACC = ACC - DY : X = X + SSX
240 LINE (BX,BY)-(X,Y),CL
250 IF Y > EY THEN GOTO 210
260 FOR J=1 TO FE
270 X(J)=X : Y(J)=Y : AX(J)=FAX(J) : AY(J)=FAY(J)
280 CL(J)=CL : CL = (CL+1) MOD 16
290 NEXT
310 F=0
320 FOR J=1 TO FE
330 IF AY ( J ) >= FEY ( J ) THEN 380
340 F=1 : BX=X(J) : BY=Y(J)
350 X(J)=X(J)+AX(J) : Y(J)=Y(J)+AY(J)
360 LINE (BX,BY)-(X(J),Y(J)),CL(J)
370 AX(J)=AX(J)+FSX(J) : AY(J)=AY(J)+1
380 NEXT
400 IF F = 1 THEN 310
420 RETURN
430 DATA 4
440 DATA 128,250,140,50, 80,250,60,80
450 DATA 200,250,180,70, 110,250,100,90
460 DATA 17
470 DATA 0.4,0,-5,6
480 DATA 1,0,-5,6,     2,-0.1,-5,6
490 DATA 2,-0.1,-4,6,  2,-0.1,-3,7
500 DATA 2,-0.1,-2,7,  2,-0.1,-1,7
510 DATA 1,0,-1,8,     0.5,0,-1,9
520 DATA -0.5,0,-1,9,  -1,0,-1,8
530 DATA -2,0.1,-1,7,  -2,0.1,-2,7
540 DATA -2,0.1,-3,7,  -2,0.1,-4,6
550 DATA -2,0.1,-5,6,  -1,0,-5,6
