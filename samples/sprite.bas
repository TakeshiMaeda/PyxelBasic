10 REM ============================================
20 REM  SPRITE DEMO
30 REM  MOVE THE PLAYER WITH THE ARROW KEYS.
40 REM  THE PLAYER ANIMATES (MOUTH OPEN/CLOSE).
50 REM  TWO STARS BOUNCE BEHIND IT (LOWER ID = FRONT).
60 REM ============================================
70 CLS 3 : VSYNC CLEAR
80 REM --- player animation frames (8x8): 0 closed, 1 open ---
90 SET SPRITE 0,"00BBBB000BBBBBB0BB7BB7BBBBBBBBBBBB8888BBBBBBBBBB0BBBBBB000BBBB00"
100 SET SPRITE 1,"00BBBB000BBBBBB0BB7BB7BBBBBBBBBBB888888BB888888B0BBBBBB000BBBB00"
110 REM --- bouncing star (8x8), colour 10 ---
120 SET SPRITE 8,"000AA00000AAAA000AAAAAA0AAAAAAAAAAAAAAAA0AAAAAA000AAAA00000AA000"
130 X=120:Y=120
140 BX=40:BY=40:BU=2:BV=1
150 CX=200:CY=70:CU=-2:CV=2
160 FR=0:TC=0
170 REM ====== main loop ======
180 S=STICK(0)
190 IF S AND 1 THEN Y=Y-2
200 IF S AND 2 THEN Y=Y+2
210 IF S AND 4 THEN X=X-2
220 IF S AND 8 THEN X=X+2
230 IF X<0 THEN X=0
240 IF X>248 THEN X=248
250 IF Y<0 THEN Y=0
260 IF Y>248 THEN Y=248
270 REM --- bounce the two stars ---
280 BX=BX+BU:IF BX<0 OR BX>248 THEN BU=-BU
290 BY=BY+BV:IF BY<0 OR BY>248 THEN BV=-BV
300 CX=CX+CU:IF CX<0 OR CX>248 THEN CU=-CU
310 CY=CY+CV:IF CY<0 OR CY>248 THEN CV=-CV
320 REM --- swap the player frame every 8 ticks ---
330 TC=TC+1:IF TC<8 THEN GOTO 360
340 TC=0:FR=1-FR
360 REM --- update the display table: id 0 = player (front) ---
370 PUT SPRITE 0,(X,Y),FR,0,0
380 PUT SPRITE 5,(BX,BY),8,0,0
390 PUT SPRITE 6,(CX,CY),8,0,0
400 VSYNC : FOR W=0 TO 200 : NEXT
410 GOTO 180
